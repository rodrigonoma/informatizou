{
  "name": "informatizou-prospect",
  "version": "0.1.0",
  "private": true,
  "description": "Plataforma Informatizou de Prospecção e Geração de Sites",
  "packageManager": "pnpm@11.0.8",
  "engines": {
    "node": ">=22"
  },
  "type": "module",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "format": "prettier --write \"**/*.{ts,vue,js,mjs,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,vue,js,mjs,json,md}\"",
    "db:generate": "pnpm --filter @informatizou/database db:generate",
    "db:migrate": "pnpm --filter @informatizou/database db:migrate:dev",
    "db:migrate:deploy": "pnpm --filter @informatizou/database db:migrate:deploy",
    "db:seed": "pnpm --filter @informatizou/database db:seed",
    "clean": "turbo run clean && rm -rf node_modules"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/node": "^22.10.0",
    "eslint": "^9.17.0",
    "prettier": "^3.4.2",
    "tsx": "^4.19.2",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.0",
    "vitest": "^2.1.8"
  }
}
